{
  "manifest_version": 3,
  "name": "Evirgen — Auto Refresh",
  "version": "1.1.1",
  "description": "Per-tab auto page refresh with presets and countdown. Zero background load.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "homepage_url": "https://kaktusdev.net",
  "author": "kaktusdev.net"
}
